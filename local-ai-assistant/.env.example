# ============================================
# LOCAL AI ASSISTANT - Environment Configuration
# ============================================
# ВАЖЛИВО: Скопіюй цей файл як .env та налаштуй під свою систему
# IMPORTANT: Copy this file as .env and configure for your system

# --- Project Paths (Dynamic, NO hardcoded paths!) ---
# ВАЖЛИВО: python-dotenv не підтримує ${VAR} синтаксис, тому шляхи вказані явно
PROJECT_ROOT=.
MODELS_DIR=./models
LOGS_DIR=./logs
DATA_DIR=./data
TEMP_DIR=./temp
CONFIG_DIR=./config

# --- Ollama Configuration ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_MAX_VRAM=5200
# VRAM threshold в MB (v1.2 patch: знижено з 5500 до 5200)
OLLAMA_TIMEOUT=120

# --- Service Ports ---
STT_SERVICE_PORT=8001
TTS_SERVICE_PORT=8002
IMAGE_SERVICE_PORT=8003
ORCHESTRATOR_PORT=8004
WEBUI_PORT=8080

# --- Hardware Monitoring ---
GPU_CHECK_INTERVAL=5
# Інтервал перевірки GPU в секундах
CPU_THRESHOLD=80
# CPU usage threshold у відсотках
RAM_THRESHOLD=85
# RAM usage threshold у відсотках

# --- Logging ---
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json
# json | text
LOG_ROTATION=10MB
# Розмір файлу для ротації логів

# --- Development ---
DEBUG_MODE=false
AUTO_RELOAD=false
# Hot reload для розробки (тільки для dev!)

# --- Phase 1 Specific ---
ORCHESTRATOR_ENABLED=true
HEALTH_CHECK_INTERVAL=30
# Інтервал health check в секундах

# PATCH v1.3: Запобігає фрагментації VRAM при частих load/unload у Windows
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
