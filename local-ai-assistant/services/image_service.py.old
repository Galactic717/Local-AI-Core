"""
Image Generation Service - Stable Diffusion Turbo FastAPI Microservice
Phase 4 - Local AI Assistant v1.0

Generates images using Stable Diffusion Turbo.
Coordinates with VRAM Orchestrator to ensure enough memory.
"""

import os
import logging
import uuid
import time
import base64
from io import BytesIO
from pathlib import Path
from typing import Optional, List

import torch
from fastapi import FastAPI, HTTPException, Body
from fastapi.responses import JSONResponse
from pydantic import BaseModel
from diffusers import AutoPipelineForText2Image
import requests

# ============================================
# CONFIGURATION
# ============================================
SERVICE_PORT = int(os.getenv("IMAGE_SERVICE_PORT", "8003"))
ORCHESTRATOR_URL = os.getenv("ORCHESTRATOR_URL", "http://localhost:8004")
MODEL_ID = os.getenv("SD_MODEL_ID", "stabilityai/sd-turbo")
DEVICE = "cuda" if torch.cuda.is_available() else "cpu"
TORCH_DTYPE = torch.float16 if DEVICE == "cuda" else torch.float32

# Шляхи
PROJECT_ROOT = Path(__file__).parent.parent
MODELS_DIR = PROJECT_ROOT / "models" / "sd_turbo"
LOGS_DIR = PROJECT_ROOT / "logs"

MODELS_DIR.mkdir(parents=True, exist_ok=True)
LOGS_DIR.mkdir(parents=True, exist_ok=True)

# ============================================
# LOGGING
# ============================================
logging.basicConfig(
    level=logging.INFO,
    format='{"time":"%(asctime)s","level":"%(levelname)s","request_id":"%(request_id)s","message":"%(message)s"}',
    handlers=[
        logging.FileHandler(LOGS_DIR / "image_service.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger("image_service")

# ============================================
# FASTAPI APP
# ============================================
app = FastAPI(
    title="Image Gen Service",
    description="Image generation service using SD Turbo",
    version="1.0.0"
)

# Pipeline instance (loaded on demand)
pipe = None

class ImageRequest(BaseModel):
    prompt: str
    negative_prompt: Optional[str] = ""
    width: int = 512
    height: int = 512
    num_inference_steps: int = 1
    guidance_scale: float = 0.0
    seed: Optional[int] = None

# ============================================
# MODEL MANAGEMENT
# ============================================
def get_pipeline():
    """Load SD Turbo pipeline"""
    global pipe
    if pipe is None:
        logger.info(f"Loading SD Turbo pipeline: {MODEL_ID}", extra={"request_id": "system"})
        try:
            pipe = AutoPipelineForText2Image.from_pretrained(
                MODEL_ID,
                torch_dtype=TORCH_DTYPE,
                variant="fp16" if TORCH_DTYPE == torch.float16 else None,
                cache_dir=str(MODELS_DIR)
            )
            pipe.to(DEVICE)
            
            # Optimization
            if DEVICE == "cuda":
                try:
                    pipe.enable_xformers_memory_efficient_attention()
                    logger.info("xformers enabled")
                except Exception as e:
                    logger.warning(f"xformers not available: {e}. Using default attention.")
                
                pipe.enable_vae_slicing()
                
            logger.info("SD Turbo pipeline loaded successfully", extra={"request_id": "system"})
        except Exception as e:
            logger.error(f"Failed to load pipeline: {e}", extra={"request_id": "system"})
            raise HTTPException(status_code=500, detail=f"Pipeline loading failed: {str(e)}")
    return pipe

def unload_pipeline():
    """Unload pipeline to free VRAM"""
    global pipe
    if pipe is not None:
        logger.info("Unloading SD Turbo pipeline", extra={"request_id": "system"})
        del pipe
        pipe = None
        if torch.cuda.is_available():
            torch.cuda.empty_cache()
        logger.info("SD Turbo pipeline unloaded, CUDA cache cleared", extra={"request_id": "system"})

# ============================================
# ORCHESTRATOR COORDINATION
# ============================================
def notify_orchestrator_prepare() -> bool:
    """Notify Orchestrator to free up VRAM for Image Gen"""
    try:
        # Image Gen needs ~3.2GB, so we tell Orchestrator to clear space
        response = requests.post(
            f"{ORCHESTRATOR_URL}/prepare/image",
            json={"required_mb": 3500},
            timeout=10
        )
        return response.status_code == 200
    except Exception as e:
        logger.warning(f"Orchestrator communication failed: {e}", extra={"request_id": "system"})
        return False

# ============================================
# ENDPOINTS
# ============================================
@app.post("/api/v1/generate")
async def generate_image_ui(request: ImageRequest):
    """Спеціальний ендпоінт для нашого React UI"""
    response = await generate_image(request)
    # Парсимо відповідь, щоб повернути чистий base64 як хоче UI
    if isinstance(response, JSONResponse):
        import json
        content = json.loads(response.body.decode())
        return {"image": content["data"][0]["b64_json"]}
    return response

@app.post("/v1/images/generations")
async def generate_image(request: ImageRequest):
    """
    OpenAI-compatible image generation endpoint.
    """
    request_id = str(uuid.uuid4())
    logger.info(f"Image request received: {request.prompt[:50]}...", extra={"request_id": request_id})
    
    # 1. Coordinate with Orchestrator (FREE VRAM)
    notify_orchestrator_prepare()
    
    try:
        # 2. Load Pipeline
        pipeline = get_pipeline()
        
        # 3. Generate
        logger.info("Starting generation...", extra={"request_id": request_id})
        start_time = time.time()
        
        generator = torch.Generator(device=DEVICE).manual_seed(request.seed) if request.seed is not None else None
        
        image = pipeline(
            prompt=request.prompt,
            negative_prompt=request.negative_prompt,
            width=request.width,
            height=request.height,
            num_inference_steps=request.num_inference_steps,
            guidance_scale=request.guidance_scale,
            generator=generator
        ).images[0]
        
        generation_time = time.time() - start_time
        logger.info(f"Generation complete in {generation_time:.2f}s", extra={"request_id": request_id})
        
        # 4. Process result
        buffered = BytesIO()
        image.save(buffered, format="PNG")
        img_str = base64.b64encode(buffered.getvalue()).decode()
        
        return JSONResponse(content={
            "created": int(time.time()),
            "data": [
                {"b64_json": img_str}
            ]
        })
        
    except Exception as e:
        logger.error(f"Generation error: {e}", extra={"request_id": request_id})
        raise HTTPException(status_code=500, detail=f"Generation failed: {str(e)}")
        
    finally:
        # 5. IMMEDIATELY Unload to free VRAM for LLM
        unload_pipeline()

@app.get("/health")
def health():
    return {"status": "ok", "service": "Image Gen Service", "device": DEVICE}

if __name__ == "__main__":
    import uvicorn
    logger.info(f"Image Gen Service starting on port {SERVICE_PORT}...", extra={"request_id": "system"})
    uvicorn.run(app, host="127.0.0.1", port=SERVICE_PORT)
